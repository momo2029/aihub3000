# App
APP_NAME=AIHub3000
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aihub3000

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# WeChat MiniProgram
WECHAT_APPID=
WECHAT_SECRET=

# Alipay MiniProgram
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=

# Douyin MiniProgram
DOUYIN_APPID=
DOUYIN_SECRET=