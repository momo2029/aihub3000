.tool-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.tool-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.tool-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tool-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
}

.tool-info {
  flex: 1;
  min-width: 0;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tool-category,
.tool-pricing {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tool-favorite {
  padding: 16rpx;
  margin: -16rpx;
}

.tool-favorite .iconfont {
  font-size: 40rpx;
}

.tool-description {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tool-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tool-tags .tag {
  font-size: 22rpx;
  color: #6366f1;
  background-color: rgba(99, 102, 241, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.tool-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}

.tool-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.stat-item .iconfont {
  font-size: 28rpx;
}

.tool-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #1f2937;
}

.tool-rating .iconfont {
  font-size: 28rpx;
}