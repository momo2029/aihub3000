.network-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4ff 0%, #f5f5f5 100%);
  padding-bottom: 40rpx;
}

/* Header */
.header {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-content .title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.header-content .subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #6366f1;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Section */
.section {
  margin: 30rpx 30rpx 0;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.section-title .iconfont {
  margin-right: 12rpx;
  color: #6366f1;
}

/* Card */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* Status Card */
.status-card .status-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.status-item {
  flex: 1;
  text-align: center;
}

.status-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.status-value {
  font-size: 36rpx;
  font-weight: 600;
}

.status-value.connected {
  color: #10b981;
}

.status-value.disconnected {
  color: #ef4444;
}

.status-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.status-indicator.online {
  background: #ecfdf5;
  color: #10b981;
}

.status-indicator.offline {
  background: #fef2f2;
  color: #ef4444;
}

.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: currentColor;
  margin-right: 12rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Device Card */
.device-card .info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.device-card .info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* IP Card */
.ip-card .ip-main {
  text-align: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ip-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.ip-value-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ip-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #6366f1;
  font-family: 'Courier New', monospace;
}

.ip-value-wrap .icon-copy {
  margin-left: 16rpx;
  color: #999;
  font-size: 32rpx;
}

.ip-detail {
  padding: 20rpx 0;
}

.ip-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.ip-detail-label {
  font-size: 26rpx;
  color: #999;
}

.ip-detail-value {
  font-size: 26rpx;
  color: #333;
}

.ipv6-section {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.ipv6-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.ipv6-value {
  font-size: 24rpx;
  color: #666;
  font-family: 'Courier New', monospace;
  word-break: break-all;
}

/* Speed Card */
.speed-card {
  text-align: center;
}

.speed-test-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.speed-test-btn.disabled {
  opacity: 0.7;
}

.speed-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.speed-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.speed-icon.testing .spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.speed-btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

/* Speed Results */
.speed-results {
  padding: 20rpx 0;
}

.result-item {
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.result-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.result-bar {
  height: 8rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #6366f1 0%, #10b981 100%);
}

.latency-bar {
  background: linear-gradient(90deg, #10b981 0%, #f59e0b 50%, #ef4444 100%);
}

/* Speed Tips */
.speed-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.tips-icon {
  margin-right: 12rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
}

/* Info Note */
.info-note {
  display: flex;
  align-items: center;
  margin: 40rpx 30rpx;
  padding: 24rpx;
  background: #fef3c7;
  border-radius: 12rpx;
}

.note-icon {
  margin-right: 12rpx;
}

.note-text {
  font-size: 24rpx;
  color: #92400e;
}

/* Share Section */
.share-section {
  margin: 40rpx 30rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  border: none;
}

.share-btn .iconfont {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.share-btn::after {
  border: none;
}