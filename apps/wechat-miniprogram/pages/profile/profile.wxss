.profile-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* User Header */
.user-header {
  position: relative;
  padding: 80rpx 32rpx 80rpx;
  margin-bottom: -40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  border-radius: 0 0 60rpx 60rpx;
}

.user-info,
.login-btn {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 20rpx;
}

.avatar.default {
  opacity: 0.8;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-text {
  font-size: 32rpx;
  color: #ffffff;
  margin-top: 16rpx;
}

/* Stats Card */
.stats-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #6b7280;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #e5e7eb;
}

/* Menu Card */
.menu-card {
  background-color: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9fafb;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon .iconfont {
  font-size: 36rpx;
  color: #6366f1;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
}

.menu-item .icon-arrow-right {
  font-size: 28rpx;
  color: #9ca3af;
}

/* Logout */
.logout-btn {
  margin: 48rpx 32rpx 24rpx;
  padding: 28rpx;
  text-align: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #ef4444;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.logout-btn:active {
  opacity: 0.8;
}

/* Version */
.version {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #9ca3af;
}