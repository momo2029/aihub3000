.index-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Header */
.header {
  position: relative;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  padding: 40rpx 32rpx;
}

.header-title {
  margin-bottom: 32rpx;
}

.header-title .title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-title .subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.search-wrap {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.search-wrap .iconfont {
  font-size: 36rpx;
  color: #9ca3af;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #9ca3af;
}

/* Section */
.section {
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-title .iconfont {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6b7280;
}

.section-more .iconfont {
  font-size: 24rpx;
  margin-left: 4rpx;
}

/* Category Grid */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.category-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.category-item:active {
  transform: scale(0.96);
}

.category-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.category-icon .iconfont {
  font-size: 44rpx;
  color: #ffffff;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 22rpx;
  color: #9ca3af;
}

/* Tools List */
.tools-list {
  margin-top: -8rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #9ca3af;
}

.empty-state .iconfont {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}