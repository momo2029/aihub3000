.detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

/* Header */
.detail-header {
  position: relative;
  height: 400rpx;
}

.tool-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.header-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.header-info {
  position: absolute;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: flex-end;
}

.tool-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-right: 24rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.tool-name {
  flex: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.tool-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.meta-item .iconfont {
  font-size: 28rpx;
}

/* Section */
.detail-section {
  background-color: #ffffff;
  padding: 32rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

/* Tags */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tags-wrap .tag {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
  color: #6366f1;
  font-size: 26rpx;
  border-radius: 24rpx;
}

/* Description */
.description {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

/* Features */
.features-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #4b5563;
}

.feature-item .iconfont {
  color: #10b981;
  font-size: 32rpx;
  margin-right: 16rpx;
}

/* Pricing */
.pricing-badge {
  display: inline-flex;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.pricing-badge.free {
  background-color: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.pricing-badge.freemium {
  background-color: rgba(99, 102, 241, 0.1);
  color: #6366f1;
}

.pricing-badge.paid {
  background-color: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

/* Actions */
.detail-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.action-btn .iconfont {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.action-btn.favorite.active {
  color: #ec4899;
}

.action-btn.primary {
  flex: 1;
  flex-direction: row;
  gap: 12rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #ffffff;
  border-radius: 48rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.action-btn.primary .iconfont {
  font-size: 32rpx;
  margin-bottom: 0;
}

/* Empty */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #9ca3af;
}

.empty-state .iconfont {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}